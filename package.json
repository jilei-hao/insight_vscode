{
  "name": "medical-image-insight",
  "displayName": "Medical Image Insight",
  "description": "Instant metadata viewer for medical imaging files: NIfTI, NRRD, VTK, VTP, VTI — no conversion needed.",
  "version": "0.3.0",
  "publisher": "jilei-hao",
  "author": {
    "name": "Jilei Hao"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/jilei-hao/insight_vscode.git"
  },
  "bugs": {
    "url": "https://github.com/jilei-hao/insight_vscode/issues"
  },
  "homepage": "https://github.com/jilei-hao/insight_vscode#readme",
  "keywords": [
    "medical imaging",
    "nifti",
    "nrrd",
    "vtk",
    "dicom",
    "metadata",
    "neuroimaging",
    "itk",
    "3d slicer"
  ],
  "categories": ["Other", "Visualization"],
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "medicalImageInsight.metadataViewer",
        "displayName": "Medical Image Metadata Viewer",
        "selector": [
          { "filenamePattern": "*.nii" },
          { "filenamePattern": "*.nii.gz" },
          { "filenamePattern": "*.nrrd" },
          { "filenamePattern": "*.seq.nrrd" },
          { "filenamePattern": "*.vtk" },
          { "filenamePattern": "*.vtp" },
          { "filenamePattern": "*.vti" }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "medicalImageInsight.showMetadata",
        "title": "Show Medical Image Metadata"
      },
      {
        "command": "medicalImageInsight.stackImages",
        "title": "Stack Images (N→N+1 Dim)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "medicalImageInsight.showMetadata",
          "when": "resourceExtname == .nii || resourceExtname == .nrrd || resourceExtname == .vtk || resourceExtname == .vtp || resourceExtname == .vti || resourceFilename =~ /\\.nii\\.gz$/ || resourceFilename =~ /\\.seq\\.nrrd$/",
          "group": "navigation"
        },
        {
          "command": "medicalImageInsight.stackImages",
          "when": "resourceExtname == .nii || resourceExtname == .nrrd || resourceFilename =~ /\\.nii\\.gz$/ || resourceFilename =~ /\\.seq\\.nrrd$/",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
